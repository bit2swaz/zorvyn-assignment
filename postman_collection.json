{
  "info": {
    "name": "Zorvyn Finance Backend",
    "description": "Postman collection for the Zorvyn finance backend. Designed for local verification with seeded users and JWT-based protected routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "0d7bf145-5ef0-45e5-a4dd-0a52948f46b2"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "jwtToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "recordId",
      "value": ""
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
